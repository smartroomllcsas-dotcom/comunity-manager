{
  "buildCommand": "npm run build",
  "outputDirectory": ".next",
  "framework": "nextjs",
  "crons": [
    {
      "path": "/api/cron/refresh-tokens",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/inbox/process-webhook-events",
      "schedule": "*/2 * * * *"
    },
    {
      "path": "/api/inbox/archive-old",
      "schedule": "30 4 * * *"
    },
    {
      "path": "/api/inbox/auto-close-idle",
      "schedule": "0 5 * * *"
    }
  ]
}
